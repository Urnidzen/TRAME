        ];

        function initWeaponSelect() {
            [1, 2].forEach(index => {
                const select = find(`weapon-select-${index}`);
                if (!select) return;
                select.innerHTML = '';
                for (const [key, category] of Object.entries(WEAPONS_DATA)) {
                    const group = document.createElement('optgroup');
                    group.label = category.label;
                    category.items.forEach(item => {
                        const option = document.createElement('option');
                        option.value = item;
                        option.textContent = item;
                        group.appendChild(option);
                    });
                    select.appendChild(group);
                }
                select.value = "Main Libre";
                select.onchange = () => {
                    updateOffhandOptions(index);
                    updateUI();
                };
                const off = find(`offhand-select-${index}`);
                if(off) off.onchange = updateUI;
                updateOffhandOptions(index);
            });
            const arm = find('armor-select');
            if(arm) arm.onchange = updateUI;
            const bloodSel = find('magical-blood-select');
            if(bloodSel) bloodSel.addEventListener('change', updateUI);
            updateUI();
        }

        function getWeaponStats(weaponName) {
            if (["Grimoire","Chapelet","Bâton","Grimoire de l'Érudit"].includes(weaponName)) return { init: "6", magie: 0 };
            for (const [key, category] of Object.entries(WEAPONS_DATA)) {
                if (category.items.includes(weaponName)) return category.stats;
            }
            return { init: "-", magie: 0 };
        }

        function getWeaponCategory(weaponName) {
            for (const [key, category] of Object.entries(WEAPONS_DATA)) {
                if (category.items.includes(weaponName)) return key;
            }
            return "Courte";
        }

        function updateOffhandOptions(index) {
            const weaponSelect = find(`weapon-select-${index}`);
            const offhandSelect = find(`offhand-select-${index}`);
            if (!weaponSelect || !offhandSelect) return;

            const weaponName = weaponSelect.value;
            const category = getWeaponCategory(weaponName);
            const currentOffhand = offhandSelect.value;
            
            offhandSelect.innerHTML = ''; 
            offhandSelect.disabled = false;
            
            let options = [];
            let defaultValue = "Main Libre";
            
            if (category === "Distance" || category === "Longue") {
                options.push("Occupée");
                offhandSelect.disabled = true;
                defaultValue = "Occupée";
            } 
            else if (category === "Focalisateur") {
                if (weaponName === "Bâton") {
                    options.push("Occupée ou Libre", "Bouclier", "Pavois Draconique", "Torche");
                    defaultValue = "Occupée ou Libre";
                }
                else {
                    options.push("Main Libre (Incantation)", "Bouclier", "Pavois Draconique", "Torche");
                    defaultValue = "Main Libre (Incantation)";
                }
            }
            else if (category === "Moyenne") {
                options.push("Main Libre", "Bouclier", "Pavois Draconique", "Torche");
            }
            else {
                options.push("Main Libre", "Bouclier", "Pavois Draconique", "Torche");
                WEAPONS_DATA["Courte"].items.forEach(wp => {
                    if (!["Main Libre","Torche","Bouclier (Offensif)"].includes(wp)) options.push(wp); 
                });
            }

            options.forEach(opt => {
                const el = document.createElement('option');
                el.value = opt; el.textContent = opt;
                offhandSelect.appendChild(el);
            });

            if (currentOffhand && Array.from(offhandSelect.options).some(o => o.value === currentOffhand)) {
                offhandSelect.value = currentOffhand;
            } else {
                offhandSelect.value = defaultValue;
            }
        }

        function updatePortrait() {
            const race = find('race-select')?.value || "HUMAIN";
            const gender = find('gender-select')?.value || "MASCULIN";
            const container = find('portrait-container');
            if(!container) return;
            const key = `${race}_${gender}`;
            if (CUSTOM_PORTRAITS_URLS[key]) {
                container.innerHTML = `<img src="${CUSTOM_PORTRAITS_URLS[key]}" class="portrait-img-custom" alt="Portrait">`;
            } else {
                container.innerHTML = `<img src="${CUSTOM_PORTRAITS_URLS["HUMAIN_MASCULIN"]}" class="portrait-img-custom" alt="Portrait">`;
            }
        }

        function updateRace() {
            const race = find('race-select')?.value;
            if (!race) return;
            Object.keys(state.talents).forEach(k => state.talents[k] = false);
            if (RULES.RACES[race]) RULES.RACES[race].forEach(tid => state.talents[tid] = true);
            const saisieField = find('stat-att-saisie');
            if(saisieField) saisieField.value = (race === "ORQUE") ? 1 : 0;
            triggerSave();
            updateUI();
        }

        function updateUI() {
            // Collect equipped items for global bonuses (like Talents)
            const equipped = [];
            let bonusDirect = 0;
            let bonusCirculaire = 0;

            [1, 2].forEach(index => {
                const weaponSelect = find(`weapon-select-${index}`);
                const offhandSelect = find(`offhand-select-${index}`);
                const initLabel = find(`init-label-${index}`);
                
                if (weaponSelect && offhandSelect) {
                    if (document.activeElement === weaponSelect) updateOffhandOptions(index);
                    
                    const weaponName = weaponSelect.value;
                    const offhandName = offhandSelect.value;
                    const weaponStats = getWeaponStats(weaponName);
                    const cat = getWeaponCategory(weaponName);

                    if (weaponName) equipped.push(weaponName);
                    if (offhandName) equipped.push(offhandName);
                    
                    const isRightFree = weaponName === "Main Libre";
                    const isLeftFree = offhandName && (offhandName.includes("Libre") || offhandName.includes("Occupée"));
                    const hasFreeHand = isRightFree || isLeftFree;
                    
                    const isRightCatalyst = !["Main Libre","Torche"].includes(weaponName);
                    const isLeftCatalyst = offhandName && !["Main Libre","Main Libre (Incantation)","Bouclier","Torche","Occupée","Occupée ou Libre"].includes(offhandName);
                    const bloodSelect = find('magical-blood-select');
                    const isOgreMage = bloodSelect && bloodSelect.value === "Sang d'Ogre Mage";
                    const isDragon = bloodSelect && bloodSelect.value === "Dragon";
                    
                    const hasCatalyst = isRightCatalyst || isLeftCatalyst || isOgreMage || isDragon;
                    const canCast = hasFreeHand && hasCatalyst;

                    const initSpan = find(`init-val-${index}`);
                    const rawInit = weaponStats.init;
                    
                    if (initSpan) {
                        if (canCast) {
                            if (initLabel) initLabel.style.display = 'none'; 
                            let weaponInitDisplay = rawInit;
                            if (weaponName === "Bâton") weaponInitDisplay = `5 <span class="font-body font-bold text-[10px]">(1m)</span> 4 <span class="font-body font-bold text-[10px]">(2m)</span>`;
                            
                            initSpan.innerHTML = `
                                <span class="font-title font-bold text-[8px] mr-1">INIT:</span>
                                <span class="font-title font-bold text-[8px] mr-1">ARME</span>${weaponInitDisplay}
                                <span class="mx-1 opacity-50 font-sans">/</span>
                                <span class="font-title font-bold text-[8px] mr-1">SORT</span>2 <span class="font-body font-bold text-[10px]">(lib)</span> 8 <span class="font-body font-bold text-[10px]">(eng)</span>
                            `;
                        } else {
                            if (initLabel) initLabel.style.display = 'inline'; 
                            let standardDisplay = rawInit;
                            if (rawInit.includes('/')) {
                                const [v1, v2] = rawInit.split('/');
                                standardDisplay = `${v1} <span class="font-body font-bold text-[10px]">(lib)</span> ${v2} <span class="font-body font-bold text-[10px]">(eng)</span>`;
                            } 
                            initSpan.innerHTML = standardDisplay;
                        }
                    }

                    const magicSpan = find(`magic-malus-${index}`);
                    if(magicSpan) {
                        if (!hasFreeHand || !hasCatalyst) {
                            magicSpan.innerText = "imp.";
                            magicSpan.style.color = "#dc2626";
                        } else {
                            const val = (cat === "Focalisateur" || isOgreMage || isDragon) ? 0 : weaponStats.magie;
                            magicSpan.innerText = val;
                            magicSpan.style.color = "#000000";
                        }
                    }

                    // Calcul des bonus d'armes magiques
                    if (MAGIC_EFFECTS[weaponName]) {
                        if (MAGIC_EFFECTS[weaponName].includes("Attaque Directe")) bonusDirect = Math.max(bonusDirect, parseInt(MAGIC_EFFECTS[weaponName].match(/\+(\d+)/)[1] || 1));
                        if (MAGIC_EFFECTS[weaponName].includes("Attaque Circulaire")) bonusCirculaire = Math.max(bonusCirculaire, parseInt(MAGIC_EFFECTS[weaponName].match(/\+(\d+)/)[1] || 1));
                    }
                    if (MAGIC_EFFECTS[offhandName]) {
                        if (MAGIC_EFFECTS[offhandName].includes("Attaque Directe")) bonusDirect = Math.max(bonusDirect, parseInt(MAGIC_EFFECTS[offhandName].match(/\+(\d+)/)[1] || 1));
                        if (MAGIC_EFFECTS[offhandName].includes("Attaque Circulaire")) bonusCirculaire = Math.max(bonusCirculaire, parseInt(MAGIC_EFFECTS[offhandName].match(/\+(\d+)/)[1] || 1));
                    }
                }
            });

            const bdEl = find('bonus-att-direct');
            if(bdEl) bdEl.innerHTML = bonusDirect > 0 ? `${bonusDirect} <span class="font-title text-[1rem] font-bold">+</span>` : '';

            const bcEl = find('bonus-att-circulaire');
            if(bcEl) bcEl.innerHTML = bonusCirculaire > 0 ? `${bonusCirculaire} <span class="font-title text-[1rem] font-bold">+</span>` : '';

            const armorEl = find('armor-select');
            if (armorEl) {
                const armor = armorEl.value;
                const armorData = RULES.ARMORS[armor];
                const baseRes = armorData ? armorData.res : 0;
                const headRes = (armor.includes("_Heaume") || armor.includes("_Casque")) ? baseRes : 0;
                
                find('res-arm-tete').innerText = headRes;
                find('res-arm-tronc').innerText = baseRes;
                find('res-arm-membres').innerText = baseRes;

                let malusArmure = 0;
                if (armorData && armorData.malus && armorData.malus.includes("magie")) malusArmure = -1;
                find('magic-malus-armor').innerText = (malusArmure >= 0 ? "+" : "") + malusArmure;

                const maxDur = armorData ? armorData.dur : 0;
                find('dur-display').innerText = `${maxDur}/${maxDur}`;

                const container = find('talents-container');
                if (container) {
                    const hasArmor = armorEl.value !== "Aucune"; // On vérifie si une armure est équipée

                    container.innerHTML = '';
                    const table = document.createElement('table');
                    table.style.cssText = "width:100%; border-collapse:collapse; table-layout:fixed;";
                    
                    // 1. L'en-tête dynamique avec la nouvelle colonne BONUS
                    table.innerHTML = `
                        <colgroup>
                            <col style="width: auto;">
                            <col style="width: 30px;">
                            ${hasArmor ? '<col style="width: 30px;">' : ''}
                            <col style="width: 30px;">
                        </colgroup>
                        <tr style="border-bottom: 1px solid rgba(0, 0, 0, 0.4);">
                            <td class="text-[8px] font-black uppercase text-black text-right pr-2" style="vertical-align:bottom; padding-bottom: 2px;">${hasArmor ? 'ARMURE :' : ''}</td>
                            <td class="text-[8px] font-black uppercase text-black text-center" style="vertical-align:bottom; padding-bottom: 2px;">${hasArmor ? 'SANS' : 'SCORE'}</td>
                            ${hasArmor ? '<td class="text-[8px] font-black uppercase text-black text-center" style="vertical-align:bottom; padding-bottom: 2px;">AVEC</td>' : ''}
                            <td class="text-[8px] font-black uppercase text-black text-center" style="vertical-align:bottom; padding-bottom: 2px;">BONUS</td>
                        </tr>`;

                    talentsList.forEach(t => {
                        const isChecked = state.talents[t.id];
                        let baseScore = isChecked ? 1 : 0; 
                        let armorMalus = 0;
                        
                        if (armorData && armorData.malus) {
                            const count = armorData.malus.filter(m => m === t.id).length;
                            armorMalus = -count;
                        }

                        // Bonus magique liés à l'équipement
                        let magicBonus = 0;
                        if (t.id === 'savoir_acad' && equipped.includes("Grimoire de l'Érudit")) {
                            magicBonus = 1;
                        }

                        // Calculs situationnels purs (indépendants du bonus manuel)
                        let scoreSansArmure = baseScore + magicBonus;
                        let scoreAvecArmure = scoreSansArmure + armorMalus;

                        // On récupère le bonus manuel s'il a été sauvegardé
                        let bonusKey = t.id + "_bonus";
                        let currentBonus = state.talents[bonusKey] || "";

                        const row = document.createElement('tr');
                        row.onmouseover = () => row.style.backgroundColor = 'rgba(0,0,0,0.05)';
                        row.onmouseout = () => row.style.backgroundColor = 'transparent';

                        // 2. Cellules de base (Nom du talent + Score) avec la classe 'clickable-cell'
                        let cellsHTML = `
                            <td class="clickable-cell" style="padding:4px 0; border-bottom:1px solid rgba(0,0,0,0.2); vertical-align:middle; cursor:pointer;">
                                <div class="check-box ${isChecked ? 'active' : ''}"></div>
                                <span style="font-weight:700; text-transform:uppercase; font-size:0.8rem; color:#000000; vertical-align:middle;">${t.label}</span>
                            </td>
                            <td class="clickable-cell" style="padding:4px 0; border-bottom:1px solid rgba(0,0,0,0.2); text-align:center; font-weight:700; font-size:1.3rem; vertical-align:middle; font-family: 'Spectral', serif; color:#000000; cursor:pointer;">${scoreSansArmure}</td>
                        `;

                        // 3. Colonne AVEC (si armure)
                        if (hasArmor) {
                            cellsHTML += `<td class="clickable-cell" style="padding:4px 0; border-bottom:1px solid rgba(0,0,0,0.2); text-align:center; font-weight:700; font-size:1.3rem; vertical-align:middle; font-family: 'Spectral', serif; color:#000000; cursor:pointer;">${scoreAvecArmure}</td>`;
                        }

                        // 4. La nouvelle colonne BONUS avec son menu déroulant
                        cellsHTML += `
                            <td style="padding:4px 0; border-bottom:1px solid rgba(0,0,0,0.2); text-align:center; vertical-align:middle;">
                                <select class="bonus-select" style="width:100%; text-align-last:center; appearance:none; background:transparent; border:none; border-bottom:2px solid rgba(0,0,0,0.3); font-family:'Spectral', serif; font-weight:700; font-size:1.1rem; outline:none; cursor:pointer; color:#000000;">
                                    <option value="" ${currentBonus === "" ? "selected" : ""}></option>
                                    <option value="-1" ${currentBonus === "-1" ? "selected" : ""}>-1</option>
                                    <option value="+1" ${currentBonus === "+1" ? "selected" : ""}>+1</option>
                                    <option value="+2" ${currentBonus === "+2" ? "selected" : ""}>+2</option>
                                </select>
                            </td>
                        `;

                        row.innerHTML = cellsHTML;

                        // 5. Comportement des clics : on sépare la case à cocher du menu déroulant
                        row.querySelectorAll('.clickable-cell').forEach(cell => {
                            cell.onclick = () => {
                                state.talents[t.id] = !state.talents[t.id];
                                triggerSave();
                                updateUI();
                            };
                        });

                        // 6. Enregistrement automatique du modificateur manuel
                        const selectEl = row.querySelector('.bonus-select');
                        selectEl.onchange = (e) => {
                            state.talents[bonusKey] = e.target.value;
                            triggerSave();
                        };

                        table.appendChild(row);
                    });

                    container.appendChild(table);
                }
            }
        }

        init();
    })();
    </script>
</body>
</html>
