            const btnExport = context.querySelector('[data-action="export"]');
            if(btnExport) btnExport.onclick = exportSingleJSON;

            // AJOUT : Gestionnaire du bouton Import
            const btnImport = context.querySelector('[data-action="import"]');
            if(btnImport) btnImport.onclick = () => {
                const fileInput = find('file-upload');
                if(fileInput) fileInput.click();
            };

            if (currentUid && typeof TRAME_Registre !== 'undefined') {
                loadFromRegistry(currentUid);
                setupAutoSave();
            }

            // AJOUT : Gestionnaire de l'input file pour l'import
            const fileInput = find('file-upload');
            if(fileInput) {
                fileInput.addEventListener('change', (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    
                    const reader = new FileReader();
                    reader.onload = (event) => {
                        try {
                            const data = JSON.parse(event.target.result);
                            if (data.content) {
                                // Charger les données dans la fiche actuelle
                                Object.keys(data.content).forEach(key => {
                                    if (key.startsWith('__clean_input_')) {
                                        const idx = parseInt(key.replace('__clean_input_', ''));
                                        const els = findAll('.clean-input:not([data-id])');
                                        if (els[idx]) els[idx].value = data.content[key];
                                    } 
                                    else if (key.startsWith('__area_')) {
                                        const idx = parseInt(key.replace('__area_', ''));
                                        const els = findAll('.area-textarea');
                                        if (els[idx]) els[idx].value = data.content[key];
                                    }
                                    else {
                                        const el = find(key);
                                        if (el) {
                                            let val = data.content[key];
                                            // Migration des anciennes sauvegardes vers les nouvelles armures
                                            if (key === 'armor-select') {
                                                const legacyMap = {
                                                    "Légère": "Cuir", "Légère_Heaume": "Cuir_Casque",
                                                    "Moyenne": "Cotte_Maille", "Moyenne_Heaume": "Cotte_Maille_Casque",
                                                    "Plaques": "Brigandine", "Plaques_Heaume": "Brigandine_Casque",
                                                    "Lourde": "Harnois", "Lourde_Heaume": "Harnois_Casque"
                                                };
                                                if (legacyMap[val]) val = legacyMap[val];
                                            }
                                            // Migration des anciennes armes vers les noms abrégés
                                            if (key.includes('weapon-select') || key.includes('offhand-select')) {
                                                const weaponLegacyMap = {
                                                    "Épée Lunaire": "Épée Lun.", "Hache Lunaire": "Hache Lun.", "Hache Lunaire (2 mains)": "Hache Lun. (2 mains)",
                                                    "Lance Diamantine (1 main)": "Lance Diam. (1 main)", "Lance Diamantine (Longue)": "Lance Diam. (Longue)", "Épée à deux mains lunaire": "Épée à deux mains lun."
                                                };
                                                if (weaponLegacyMap[val]) val = weaponLegacyMap[val];
                                            }
                                            if (el.type === 'checkbox') el.checked = val;
                                            else el.value = val;
                                        }
                                    }
                                });
                                
                                if (data.content.__state_talents) {
                                    state.talents = JSON.parse(JSON.stringify(data.content.__state_talents));
                                }
                                
                                updateUI();
                                updatePortrait();
                                triggerSave();
                                alert('Personnage chargé avec succès !');
                            } else {
                                alert('Format de fichier invalide');
                            }
                        } catch (err) {
                            alert('Erreur lors du chargement du fichier JSON');
                            console.error(err);
                        }
                        // Reset pour permettre de re-sélectionner le même fichier
                        e.target.value = '';
                    };
                    reader.readAsText(file);
                });
